# =============================================================
# Variables de entorno — SP Confort Infinity (oficial)
# Archivo local: .env.local
# NUNCA subir .env.local a GitHub
# =============================================================

# --- Base de datos PostgreSQL (Supabase o servidor local en Contabo) ---
# DATABASE_URL: conexión principal de la app
# DIRECT_URL: conexión para migraciones (en Postgres local puede ser igual)

DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
# Generá uno mejor después con: npx auth secret
AUTH_SECRET="sp-confort-infinity-secret-local-cambiar-en-produccion"

# --- Admin inicial (definí una contraseña segura, NO la dejes de ejemplo) ---
ADMIN_EMAIL="admin@spconfortinfinity.com"
ADMIN_PASSWORD="DEFINIR_CONTRASENA_SEGURA"

# --- Imágenes ---
# Las imágenes del panel se guardan en el servidor local: public/uploads/products
# No requiere Supabase Storage ni variables adicionales.

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER="595976160007"
NEXT_PUBLIC_WHATSAPP_DISPLAY="0976 160 007"
