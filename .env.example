# =============================================================
#  Variables de entorno — SP Confort Infinity (oficial)
#  Copiá este archivo a .env.local y completá los valores.
#  NUNCA subas .env / .env.local a GitHub (ya están en .gitignore).
# =============================================================

# --- Base de datos (Supabase Postgres) ---
# DATABASE_URL: conexión "pooled" (pgBouncer, puerto 6543) -> usada por la app.
# DIRECT_URL:   conexión directa (puerto 5432) -> usada por las migraciones.
# Las obtenés en Supabase > Project Settings > Database > Connection string.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-xx.pooler.supabase.com:5432/postgres"

# --- Auth.js (panel admin) ---
# Generá un secreto seguro con:  npx auth secret   (o  openssl rand -base64 32)
AUTH_SECRET="reemplazar-por-un-secreto-largo-y-aleatorio"
# En producción, la URL pública del sitio (Vercel la setea sola, pero podés fijarla):
# AUTH_URL="https://tudominio.com"

# --- Admin inicial (lo usa el seed para crear el usuario) ---
ADMIN_EMAIL="admin@spconfortinfinity.com"
ADMIN_PASSWORD="CambiarEstaClave123!"

# --- Supabase Storage (subida de imágenes desde el panel) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role...."   # SOLO servidor, secreto
SUPABASE_STORAGE_BUCKET="products"                    # bucket público de imágenes

# --- WhatsApp (centralizado) ---
NEXT_PUBLIC_WHATSAPP_NUMBER="595976160007"
NEXT_PUBLIC_WHATSAPP_DISPLAY="0976 160 007"
